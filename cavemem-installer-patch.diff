From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: cave WS7 <noreply@cave.sh>
Date: Tue, 28 Apr 2026 21:00:00 +0000
Subject: [PATCH] Add `cave` IDE installer to packages/installers

Mirrors the existing claude-code installer: registers the 5 lifecycle hook
stubs against `~/.cave/settings.json`'s `hooks` key (Claude Code-format,
which cave is byte-compatible with — see Cave v2 master plan §9), and adds
`cavemem` to `mcpServers` in the same file. Spawns Node explicitly so
Windows survives EFTYPE on the .js launcher.

Cave's settings.json schema for hooks/mcpServers is verbatim Claude Code
v2.1.119 — see https://code.claude.com/docs/en/hooks. A user with both
agents installed can therefore share one cavemem worker across them.

NOTE: This patch is *prepared* for upstream submission. It is NOT pushed
to JuliusBrussee/cavemem yet — the cave team will hand it off after the
WS7 merge. See packages/agent/src/memory/cavemem.ts for the cave side
that talks to this installer's output.
---
 packages/installers/src/cave.ts          | 79 ++++++++++++++++++++++++
 packages/installers/src/registry.ts      |  6 +-
 packages/installers/test/installers.test.ts |  4 +-
 3 files changed, 86 insertions(+), 3 deletions(-)
 create mode 100644 packages/installers/src/cave.ts

diff --git a/packages/installers/src/cave.ts b/packages/installers/src/cave.ts
new file mode 100644
index 0000000..0000001
--- /dev/null
+++ b/packages/installers/src/cave.ts
@@ -0,0 +1,79 @@
+import { existsSync } from 'node:fs';
+import { homedir } from 'node:os';
+import { join } from 'node:path';
+import { deepMerge, readJson, shellQuote, writeJson } from './fs-utils.js';
+import type { InstallContext, Installer } from './types.js';
+
+interface CaveSettings {
+  hooks?: Record<
+    string,
+    Array<{ matcher?: string; hooks: Array<{ type: string; command: string }> }>
+  >;
+  mcpServers?: Record<string, { command: string; args?: string[]; env?: Record<string, string> }>;
+}
+
+const HOOK_NAMES: Array<[string, string]> = [
+  ['SessionStart', 'session-start'],
+  ['UserPromptSubmit', 'user-prompt-submit'],
+  ['PostToolUse', 'post-tool-use'],
+  ['Stop', 'stop'],
+  ['SessionEnd', 'session-end'],
+];
+
+function settingsFile(): string {
+  return join(homedir(), '.cave', 'settings.json');
+}
+
+export const cave: Installer = {
+  id: 'cave',
+  label: 'Cave CLI',
+  async detect(_ctx: InstallContext): Promise<boolean> {
+    // Cave creates ~/.cave on first run; we also accept the binary on PATH
+    // since some users install via curl|sh into /usr/local/bin without ever
+    // launching it before installing cavemem.
+    return existsSync(join(homedir(), '.cave'));
+  },
+  async install(ctx: InstallContext): Promise<string[]> {
+    const path = settingsFile();
+    const current = readJson<CaveSettings>(path, {});
+    const hooks: CaveSettings['hooks'] = { ...(current.hooks ?? {}) };
+    // Quote both bin and CLI path for cmd.exe + sh; Windows install paths
+    // routinely contain spaces.
+    const nodeBin = shellQuote(ctx.nodeBin);
+    const cliPath = shellQuote(ctx.cliPath);
+    for (const [caveName, hookId] of HOOK_NAMES) {
+      hooks[caveName] = [
+        {
+          hooks: [
+            {
+              type: 'command',
+              command: `${nodeBin} ${cliPath} hook run ${hookId} --ide cave`,
+            },
+          ],
+        },
+      ];
+    }
+    const mcpServers = {
+      ...(current.mcpServers ?? {}),
+      cavemem: {
+        // Spawn Node explicitly — cave's MCP launcher (like Claude Code's)
+        // can't exec a .js file directly on Windows (EFTYPE).
+        command: ctx.nodeBin,
+        args: [ctx.cliPath, 'mcp'],
+      },
+    };
+    const next = deepMerge<CaveSettings>(current, { hooks, mcpServers });
+    writeJson(path, next);
+    return [`wrote ${path}`];
+  },
+  async uninstall(_ctx: InstallContext): Promise<string[]> {
+    const path = settingsFile();
+    const current = readJson<CaveSettings>(path, {});
+    if (current.hooks) {
+      for (const [caveName] of HOOK_NAMES) delete current.hooks[caveName];
+    }
+    if (current.mcpServers) delete current.mcpServers.cavemem;
+    writeJson(path, current);
+    return [`updated ${path}`];
+  },
+};
diff --git a/packages/installers/src/registry.ts b/packages/installers/src/registry.ts
index 0000002..0000003 100644
--- a/packages/installers/src/registry.ts
+++ b/packages/installers/src/registry.ts
@@ -1,16 +1,18 @@
+import { cave } from './cave.js';
 import { claudeCode } from './claude-code.js';
 import { codex } from './codex.js';
 import { cursor } from './cursor.js';
 import { geminiCli } from './gemini-cli.js';
 import { openCode } from './opencode.js';
 import type { Installer } from './types.js';

-export type IdeName = 'claude-code' | 'gemini-cli' | 'opencode' | 'codex' | 'cursor';
+export type IdeName = 'claude-code' | 'gemini-cli' | 'opencode' | 'codex' | 'cursor' | 'cave';

 export const installers: Record<IdeName, Installer> = {
   'claude-code': claudeCode,
   'gemini-cli': geminiCli,
   opencode: openCode,
   codex,
   cursor,
+  cave,
 };

 export function getInstaller(name: string): Installer {
   const found = installers[name as IdeName];
   if (!found) throw new Error(`Unknown IDE: ${name}. Known: ${Object.keys(installers).join(', ')}`);
   return found;
 }

 export type { Installer, InstallContext } from './types.js';
diff --git a/packages/installers/test/installers.test.ts b/packages/installers/test/installers.test.ts
index 0000004..0000005 100644
--- a/packages/installers/test/installers.test.ts
+++ b/packages/installers/test/installers.test.ts
@@ -27,9 +27,9 @@ afterEach(() => {

 describe('registry', () => {
   it('exposes all expected installers', () => {
     expect(Object.keys(installers).sort()).toEqual(
-      ['claude-code', 'codex', 'cursor', 'gemini-cli', 'opencode'].sort(),
+      ['cave', 'claude-code', 'codex', 'cursor', 'gemini-cli', 'opencode'].sort(),
     );
   });
   it('getInstaller throws on unknown id', () => {
     expect(() => getInstaller('nope')).toThrow(/Unknown IDE/);
   });
 });
